{
  "name": "@noscrape/js",
  "version": "0.1.0",
  "description": "Official framework-agnostic JavaScript SDK for Noscrape. Protect email addresses, phone numbers and other sensitive text from bots while remaining fully readable for humans.",
  "license": "MIT",
  "author": {
    "name": "Bernhard Schönberger",
    "url": "https://noscrape.eu"
  },
  "homepage": "https://noscrape.eu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noscrape/noscrape-js.git"
  },
  "bugs": {
    "url": "https://github.com/noscrape/noscrape-js/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://noscrape.eu"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "noscrape",
    "anti-scraping",
    "scraping",
    "bot-protection",
    "email-protection",
    "email-obfuscation",
    "phone-obfuscation",
    "privacy",
    "javascript",
    "typescript",
    "browser",
    "frontend"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
